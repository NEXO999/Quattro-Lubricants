              }
            },
            "& when (@reverseContent)": {
              ".main-row": {
                "flex-direction": "row-reverse"
              }
            },
            ".mbr-section-title": {
              "text-align": "center",
              "color": "#ffa600"
            },
            ".mbr-text, .mbr-section-btn": {
              "text-align": "center"
